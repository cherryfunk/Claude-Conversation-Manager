{
  "name": "ccm",
  "displayName": "Claude Conversation Manager",
  "description": "View and manage Claude Code conversations as interactive trees",
  "version": "0.1.0",
  "publisher": "cherryfunk",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": ["onWebviewPanel:ccm"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccm.open",
        "title": "CCM: Open Conversation Manager"
      }
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@ccm/shared": "file:../shared"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
